---
import type { Release } from "../lib/releases";

type Props = {
  release: Release;
};

const { release } = Astro.props;
const audioId = `audio-${release.slug}`;
const remainingId = `remaining-time-${release.slug}`;
const remainingTimeLabel =
  typeof release.durationSeconds === "number"
    ? formatDuration(release.durationSeconds)
    : null;

function formatDuration(seconds: number): string {
  const minutes = Math.floor(seconds / 60);
  const remainingSeconds = Math.floor(seconds % 60);
  return `${minutes}:${remainingSeconds.toString().padStart(2, "0")}`;
}
---

<article id={release.slug} class="card">
  <header>
    <h3 class="song name">
      <span class="random-emoji">{release.emoji}</span>
      {release.id}
    </h3>
    {release.isNew && <span class="new-label caption">New</span>}
  </header>

  <footer>
    <div class="song controls">
      <audio id={audioId} preload="metadata" src={release.audioUrl}></audio>

      <button
        type="button"
        class="player-toggle"
        data-audio-id={audioId}
        aria-label={`Play ${release.id}`}
      >
        <span class="material-symbols-sharp icon icon-play">play_arrow</span>
        <span class="material-symbols-sharp icon icon-pause">pause</span>
      </button>

      <div class="song progress">
        <h5
          class="song remaining-time"
          id={remainingId}
          data-duration-seconds={release.durationSeconds ?? undefined}
        >
          {remainingTimeLabel ?? <span class="spinner" aria-hidden="true"></span>}
        </h5>
        <div class="song track inactive" data-audio-id={audioId}>
          <div class="song track active" style="width: 0%;"></div>
        </div>
      </div>
    </div>

    <a class="download" href={release.downloadUrl} target="_blank" rel="noreferrer" download>
      <div class="tooltip caption waveText">Download project files</div>
      <span class="material-symbols-sharp icon">download_2</span>
    </a>
  </footer>
</article>
